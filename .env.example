# Server
PORT=3900
NODE_ENV=development

# Database (PostgreSQL on arcana-db via Tailscale)
DATABASE_URL=postgresql://<DB_USER>:<DB_PASSWORD>@<DB_HOST>:5432/<DB_NAME>

# Redis (arcana-db via Tailscale)
REDIS_HOST=100.70.137.104
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_PREFIX=conn:

# Auth
API_KEY_SALT_ROUNDS=10

# Connectors
CONNECTOR_TIMEOUT_MS=300000
CONNECTOR_MAX_CONCURRENCY=1

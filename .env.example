# Server
PORT=3900
NODE_ENV=development

# Database (PostgreSQL on arcana-db via Tailscale)
DATABASE_URL=postgresql://user:password@100.70.137.104:5432/arcanada_connector

# Redis (arcana-db via Tailscale)
REDIS_HOST=100.70.137.104
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_PREFIX=conn:

# Auth
API_KEY_SALT_ROUNDS=10
ADMIN_TOKEN=  # Min 32 chars. Required for /admin/keys endpoints. Generate: openssl rand -hex 32

# Connectors
CONNECTOR_TIMEOUT_MS=300000
CONNECTOR_MAX_CONCURRENCY=1

# Codex CLI (CONN-0062)
CODEX_MAX_CONCURRENCY=4

# Codex sidecar — Vault AppRole credentials (operator-provisioned, never committed).
# Read role: entrypoint fetches the OAuth blob from Vault (read-only).
CODEX_VAULT_ROLE_ID=
CODEX_VAULT_SECRET_ID=
# Writeback role (CONN-0222): dedicated AppRole, create+update on
# arcanada/data/prod/env/codex-cli only. Consumed by codex-oauth-writeback.sh to
# persist the rotated OAuth token back to Vault (KV-v2 CAS). Empty = writeback
# disabled (fail-open) until the operator provisions the role (H1). Distinct from
# the read role above; HCL draft in
# documentation/infrastructure/vault-secondary-bootstrap/codex-oauth-recovery.md.
CODEX_WRITEBACK_ROLE_ID=
CODEX_WRITEBACK_SECRET_ID=

# Cursor CLI (standalone agent binary)
CURSOR_API_KEY=

# OpenRouter API
OPENROUTER_API_KEY=

# xAI (Grok) API
XAI_API_KEY=
GROK_MAX_CONCURRENCY=10

# Embedding API (BGE-M3 on arcana-db via Tailscale)
EMBEDDING_API_URL=http://100.70.137.104:8300
EMBEDDING_TIMEOUT_MS=30000

# OpenModel API (CONN-0223)
# CONN-0244: OpenModel is a PAID gateway — it has NO free models. Leave OPENMODEL_FREE_MODELS
# EMPTY unless the account genuinely receives a provider free allowance; a stray value here
# re-introduces the false-free bug that drove paid traffic through the free cascade.
OPENMODEL_ENABLED=false
OPENMODEL_API_KEY=
OPENMODEL_BASE_URL=https://api.openmodel.ai/v1
OPENMODEL_FREE_MODELS=
OPENMODEL_TIMEOUT_MS=30000
OPENMODEL_MAX_CONCURRENCY=2

# Low-reasoning cascade router (CONN-0223)
# CONN-0244: DEEPENED to ~7 live free rungs across groq + openrouter (each prod-probed:
# status=success, cost=0), interleaved for cross-provider resilience. free rungs must be
# GENUINELY free — do NOT put openmodel:* (paid) on a :free rung. Model ids may NOT contain a
# colon (tier = text after the last colon), so openrouter `:free`-suffixed ids are unusable here.
CASCADE_LOW_REASONING_ORDER=groq:llama-3.3-70b-versatile:free,groq:llama-3.1-8b-instant:free,openrouter:meta-llama/llama-4-maverick:free,groq:meta-llama/llama-4-scout-17b-16e-instruct:free,groq:openai/gpt-oss-120b:free,openrouter:openrouter/free:free,groq:qwen/qwen3-32b:free,openrouter:deepseek-v4-flash:paid

# Per-provider access (CONN-0244) — CSV `name:level` (level = use | read | none):
#   use  = fully enabled (default for any provider not listed)
#   read = visible in catalog but NOT routable (no cascade, no /execute) — marked access:read-only
#   none = hidden from the catalog entirely
# Default keeps OpenModel visible-but-not-routable (paid gateway the operator cannot fund).
PROVIDER_ACCESS=openmodel:read
CASCADE_PAID_ENABLED=false
CASCADE_PAID_DAILY_BUDGET_USD=0.17
CASCADE_PAID_MODEL=deepseek-v4-flash

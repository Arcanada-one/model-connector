generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Request {
  id           String   @id @default(uuid())
  connector    String
  model        String?
  promptHash   String
  promptLength Int
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  totalTokens  Int      @default(0)
  costUsd      Decimal  @default(0) @db.Decimal(10, 6)
  latencyMs    Int
  status       String // 'success', 'error', 'timeout', 'rate_limited'
  errorType    String?
  errorMessage String?
  apiKeyId     String
  apiKey       ApiKey   @relation(fields: [apiKeyId], references: [id])
  createdAt    DateTime @default(now())

  @@index([connector, createdAt])
  @@index([apiKeyId, createdAt])
  @@index([status])
}

model ApiKey {
  id        String    @id @default(uuid())
  name      String
  keyHash   String    @unique
  rateLimit Int       @default(60)
  active    Boolean   @default(true)
  requests  Request[]
  createdAt DateTime  @default(now())
}

model ConnectorAccount {
  id             String  @id @default(uuid())
  connector      String
  accountName    String
  credentials    String
  maxConcurrency Int     @default(1)
  active         Boolean @default(true)

  @@unique([connector, accountName])
}

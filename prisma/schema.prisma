generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Request {
  id           String   @id @default(uuid())
  connector    String
  model        String?
  promptHash   String
  promptLength Int
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  totalTokens  Int      @default(0)
  costUsd      Decimal  @default(0) @db.Decimal(10, 6)
  latencyMs    Int
  status       String // 'success', 'error', 'timeout', 'rate_limited'
  errorType    String?
  errorMessage String?
  apiKeyId     String
  apiKey       ApiKey   @relation(fields: [apiKeyId], references: [id])
  // CONN-0089 output-guard middleware envelope (nullable for backward-compat)
  repairReport Json?
  createdAt    DateTime @default(now())

  @@index([connector, createdAt])
  @@index([apiKeyId, createdAt])
  @@index([status])
}

model ApiKey {
  id                String             @id @default(uuid())
  name              String
  keyHash           String             @unique
  rateLimit         Int                @default(60)
  active            Boolean            @default(true)
  requests          Request[]
  imageGenerations  ImageGeneration[]
  sttTranscriptions SttTranscription[]
  createdAt         DateTime           @default(now())
}

model ConnectorAccount {
  id             String  @id @default(uuid())
  connector      String
  accountName    String
  credentials    String
  maxConcurrency Int     @default(1)
  active         Boolean @default(true)

  @@unique([connector, accountName])
}

// CONN-0052: Image Generation models
// PK uses app-side UUID v7 (uuidv7 lib) — NOT @default(uuid()) which is v4
// Migration deferred to Phase 1 (pnpm db:migrate)

model ImageGeneration {
  id            String   @id // UUID v7, set by application layer
  apiKeyId      String
  apiKey        ApiKey   @relation(fields: [apiKeyId], references: [id])
  provider      String // 'vertex' | 'replicate' | 'openai-images'
  model         String
  prompt        String
  negativePrompt String?
  width         Int      @default(1024)
  height        Int      @default(1024)
  steps         Int?
  cfg           Float?   // classifier-free guidance scale
  seed          Int?
  aspectRatio   String?  // e.g. '16:9', '1:1'
  outputFormat  String   @default("png") // 'png' | 'jpeg' | 'webp'
  status        String   // 'pending' | 'processing' | 'completed' | 'failed' | 'cancelled'
  resultUrl     String?  // presigned R2 URL or direct URL
  r2Key         String?  // R2 object key for storage management
  costUsd       Decimal  @default(0) @db.Decimal(10, 6)
  latencyMs     Int?
  errorType     String?
  errorMessage  String?
  metadata      String?  // JSON blob for provider-specific fields
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  jobs          ImageJob[]

  @@index([provider, createdAt])
  @@index([apiKeyId, createdAt])
  @@index([status])
}

model ImageJob {
  id              String          @id // UUID v7, set by application layer
  imageGenerationId String
  imageGeneration ImageGeneration @relation(fields: [imageGenerationId], references: [id])
  bullJobId       String?         // BullMQ job ID for async tracking
  attempt         Int             @default(1)
  status          String          // 'queued' | 'processing' | 'completed' | 'failed'
  startedAt       DateTime?
  completedAt     DateTime?
  errorMessage    String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([imageGenerationId])
  @@index([bullJobId])
  @@index([status, createdAt])
}

// CONN-0102: STT multi-provider router audit row
// PK = UUID v7 (app-side via uuidv7 lib) for time-sortable scans.
// CONN-0103: adds fallbackCount + driftStatus (Phase 1b cascade audit).
// CONN-0104: adds mode (sync|async) + jobId (uuidv7) for Phase 2 async pipeline.
model SttTranscription {
  id                   String   @id // UUID v7, set by application layer
  apiKeyId             String
  apiKey               ApiKey   @relation(fields: [apiKeyId], references: [id])
  provider             String // 'groq' | 'deepgram' | 'assemblyai' | 'openai' | 'local-whisper'
  model                String
  language             String?
  audioBytes           Int
  audioDurationSeconds Float?
  mimeType             String
  transcriptionPreview String // first 80 chars of returned transcription (PII surface — keep short)
  costUsd              Decimal  @default(0) @db.Decimal(10, 6)
  latencyMs            Int
  status               String // 'success' | 'error' | 'queued' | 'processing' (async-only states)
  errorType            String? // includes 'drift' from Phase 1b
  errorMessage         String?
  requestId            String?
  fallbackCount        Int      @default(0) // cascade hops before this row landed
  driftStatus          String? // null | 'schema_pass' | 'schema_fail' (Phase 1b drift detection)
  mode                 String   @default("sync") // 'sync' | 'async' (CONN-0104)
  jobId                String?  @unique // BullMQ job id (uuidv7) — only set for mode='async'
  createdAt            DateTime @default(now())

  @@index([provider, createdAt])
  @@index([apiKeyId, createdAt])
  @@index([status])
}

// CONN-0245: DB as single source of truth for the model catalog.
// Populated exclusively by CatalogRefreshService (cron full-refresh +
// interval status-refresh) — the getCatalog() request path only ever reads
// this table (+ optional Redis cache), never calls a provider directly.
// Rows are never deleted: when a model disappears from a provider's live
// list, `absent` flips to true and the last-known data is retained for
// history/audit instead of losing the row.
model ModelCatalog {
  id                 String   @id @default(cuid())
  connector          String
  model              String
  modality           String
  status             String // "online" | "offline"
  lastChecked        DateTime
  supportsStreaming  Boolean  @default(false)
  supportsJsonSchema Boolean  @default(false)
  supportsTools      Boolean  @default(false)
  inputPerMTok       Float?
  outputPerMTok      Float?
  priceUnit          String   @default("USD/1M tokens")
  tier               String // "free" | "paid" | "unknown"
  free               Boolean  @default(false)
  // QA FIX B (Finding 1) — the legacy MC-side price multiplier (0 = free;
  // 1 = standard; null = unknown; OPENMODEL_CATALOGUE-sourced). Persisted
  // verbatim (not consulted for tier/free — see catalog-mapper.ts deriveTier)
  // so the external site's `cheap`/`priceMultiplier` fields survive the DB
  // round-trip unchanged instead of being fabricated on read.
  priceMultiplier    Float?
  contextWindow      Int?
  maxOutputTokens    Int?
  endpoint           String?
  executableHere     Boolean  @default(false)
  // CONN-0244 — per-provider USE access (`ProviderAccess.use`), persisted
  // verbatim so the read path can reconstruct the `access:read-only` tag.
  // NOT a compound of useEnabled && executableHere — availability for
  // routing is derived separately (see `available`, computed from `status`
  // at persist time in catalog-mapper.ts's entryToRow/rowToEntry).
  routable           Boolean  @default(false)
  firstSeen          DateTime @default(now())
  lastSeen           DateTime
  absent             Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([connector, model])
  @@index([modality])
  @@index([status])
  @@map("model_catalog")
}

// CONN-0245-EXT — per-provider READ/USE access state. DB is authoritative;
// config (CATALOG_PROVIDER_USE_DEFAULT_OFF) only seeds defaults for a
// provider the FIRST time it's seen (create-only — see
// ProviderAccessService.seedDefaults). readEnabled gates catalog visibility;
// useEnabled gates whether MC routes traffic to it (execute()/cascade).
// Driving case: OpenModel is paid and the operator hasn't topped up ->
// readEnabled=true (still shown, real prices, not falsely free) /
// useEnabled=false (never routed).
model ProviderAccess {
  provider    String   @id
  readEnabled Boolean  @default(true)
  useEnabled  Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("provider_access")
}
